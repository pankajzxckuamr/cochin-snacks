# =============================================================================
# COCHIN SNACKS — Production Environment Variables Template
# =============================================================================

# ── Sanity CMS ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Server-only write token (Never prefix with NEXT_PUBLIC_)
# Obtain from Sanity Manage portal (Editor/Administrator permissions required)
SANITY_API_TOKEN=

# ── Google Analytics ─────────────────────────────────────────────────────────
# Replace with your Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Resend (Email Provider) ──────────────────────────────────────────────────
# API key obtained from resend.com
RESEND_API_KEY=
